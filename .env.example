# === API 認證 ===
# 產生方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=sk-your-secret-api-key-here

# === OpenClaw AI Gateway ===
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=clawx-your-token

# === REST 伺服器 ===
REST_PORT=3090
REST_HOST=127.0.0.1

# === 4 個 WhatsApp 實例（whatsapp-web-api-rest） ===
WA_INSTANCE_1=http://127.0.0.1:8085
WA_INSTANCE_2=http://127.0.0.1:8086
WA_INSTANCE_3=http://127.0.0.1:8087
WA_INSTANCE_4=http://127.0.0.1:8088

# === 實例標籤 ===
WA_LABEL_1=客服一號
WA_LABEL_2=客服二號
WA_LABEL_3=客服三號
WA_LABEL_4=客服四號

# === Webhook 簽名 ===
WEBHOOK_SECRET=

# === Cloudflare WebSocket Hub ===
HUB_WS_URL=wss://whatsapp-gateway-hub.ai-caseylai.workers.dev
CONNECTOR_SECRET=connector-secret-change-me
GATEWAY_LOCAL_URL=http://127.0.0.1:3090

# === 速率限制 ===
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
